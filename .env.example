# Hue & Heal — Studio Co-pilot :: frontend environment
# Copy to `.env.local` and fill in from your Supabase project settings.
# Leaving these blank runs the app in "local mode" (in-memory data, on-device
# template generation) — useful for previewing without a backend.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NOTE: server-side secrets (ANTHROPIC_API_KEY, OPENAI_API_KEY, etc.) are NOT set
# here. They live on the edge functions — see SETUP.md.
